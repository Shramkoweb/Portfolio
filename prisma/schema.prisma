generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model views {
  slug  String @id @db.VarChar(128)
  count BigInt @default(1)
}

model reactions {
  id    Int    @id @default(autoincrement())
  slug  String @db.VarChar(128)
  type  String @db.VarChar(32)
  count BigInt @default(0)

  @@unique([slug, type])
}
